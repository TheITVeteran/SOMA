# SOMA API Keys — copy this file to api-keys.env and fill in your values
# cp config/api-keys.env.example config/api-keys.env

# ── Primary Brain (need at least one) ────────────────────────────────────────

# DeepSeek — recommended primary. Fast, cheap, large context window.
# Get key: https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-key-here

# Ollama (local, no key needed — just have Ollama running)
# Install: https://ollama.com  |  then: ollama pull gemma3:4b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# ── Fallback LLMs (optional) ──────────────────────────────────────────────────

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-key-here

# Groq — fast inference fallback — https://console.groq.com/
GROQ_API_KEY=your-groq-key-here

# ── Web Search ────────────────────────────────────────────────────────────────

# Brave Search — 500 free queries/month. Reserved for user queries only.
# SOMA's CuriosityEngine uses free scrapers first (Wikipedia, arXiv, HN, GitHub).
# Get key: https://brave.com/search/api/
BRAVE_API_KEY=your-brave-key-here

# ── Server ────────────────────────────────────────────────────────────────────

NODE_ENV=production
LOG_LEVEL=info
